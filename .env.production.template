# =============================================================================
# .env.production — ServiceNow MCP Server (self-hosted)
# =============================================================================
# Copy this file to .env.production and fill in the values.
# IMPORTANT: chmod 600 .env.production to restrict access.
# =============================================================================

# --- ServiceNow credentials (server-side only, never exposed to clients) ---
SERVICENOW_INSTANCE_URL=https://mashgin.service-now.com
SERVICENOW_AUTH_TYPE=oauth
SERVICENOW_CLIENT_ID=<your-client-id>
SERVICENOW_CLIENT_SECRET=<your-client-secret>
# SERVICENOW_USERNAME=         # Only needed for password grant OAuth
# SERVICENOW_PASSWORD=         # Only needed for password grant OAuth

# --- MCP server client authentication ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
MCP_AUTH_TOKEN=<generate-a-strong-random-token>

# --- Tool package (limits which tools are exposed) ---
# Options: full, customer_service, service_desk
MCP_TOOL_PACKAGE=customer_service

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=<tunnel-token-from-cf-dashboard>
