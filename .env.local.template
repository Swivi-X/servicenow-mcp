# =============================================================================
# .env.local — ServiceNow MCP Server (local development)
# =============================================================================
# Copy this file to .env and fill in your ServiceNow credentials.
# This runs the MCP server locally via stdio (for Claude Desktop / Claude Code).
# No Docker, no tunnel, no Bearer auth — just direct ServiceNow access.
# =============================================================================

# --- ServiceNow instance ---
SERVICENOW_INSTANCE_URL=https://mashgin.service-now.com

# --- Authentication (choose one) ---

# Option A: OAuth (recommended)
SERVICENOW_AUTH_TYPE=oauth
SERVICENOW_CLIENT_ID=<your-servicenow-client-id>
SERVICENOW_CLIENT_SECRET=<your-servicenow-client-secret>
# SERVICENOW_USERNAME=         # Only needed for password grant
# SERVICENOW_PASSWORD=         # Only needed for password grant

# Option B: Basic auth
# SERVICENOW_AUTH_TYPE=basic
# SERVICENOW_USERNAME=<your-username>
# SERVICENOW_PASSWORD=<your-password>

# --- Tool package ---
# Options: full, customer_service, service_desk
MCP_TOOL_PACKAGE=customer_service
